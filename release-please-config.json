{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "extra-files": [
    {
      "type": "json",
      "path": "examples/ore-react/package.json",
      "jsonpath": "$.dependencies['@usearete/react']"
    },
    {
      "type": "json",
      "path": "examples/ore-react/package.json",
      "jsonpath": "$.dependencies['@usearete/stacks']"
    },
    {
      "type": "json",
      "path": "examples/ore-typescript/package.json",
      "jsonpath": "$.dependencies['@usearete/sdk']"
    },
    {
      "type": "json",
      "path": "examples/ore-typescript/package.json",
      "jsonpath": "$.dependencies['@usearete/stacks']"
    },
    {
      "type": "toml",
      "path": "examples/ore-rust/Cargo.toml",
      "jsonpath": "$.dependencies['arete-sdk'].version"
    },
    {
      "type": "toml",
      "path": "examples/ore-rust/Cargo.toml",
      "jsonpath": "$.dependencies['arete-stacks'].version"
    }
  ],
  "packages": {
    "arete": {
      "release-type": "rust",
      "component": "arete"
    },
    "interpreter": {
      "release-type": "rust",
      "component": "arete-interpreter"
    },
    "arete-macros": {
      "release-type": "rust",
      "component": "arete-macros"
    },
    "cli": {
      "release-type": "rust",
      "component": "a4-cli"
    },
    "rust/arete-sdk": {
      "release-type": "rust",
      "component": "arete-sdk"
    },
    "rust/arete-auth": {
      "release-type": "rust",
      "component": "arete-auth"
    },
    "rust/arete-auth-server": {
      "release-type": "rust",
      "component": "arete-auth-server"
    },
    "rust/arete-server": {
      "release-type": "rust",
      "component": "arete-server"
    },
    "rust/arete-mcp": {
      "release-type": "rust",
      "component": "arete-mcp"
    },
    "typescript/react": {
      "release-type": "node",
      "component": "arete-react"
    },
    "typescript/core": {
      "release-type": "node",
      "component": "arete-typescript"
    },
    "stacks/sdk/typescript": {
      "release-type": "node",
      "component": "arete-stacks"
    },
    "stacks/sdk/rust": {
      "release-type": "rust",
      "component": "arete-stacks"
    },
    "packages/arete": {
      "release-type": "node",
      "component": "a4-npm"
    },
    "arete-idl": {
      "release-type": "rust",
      "component": "arete-idl"
    }
  },
  "plugins": [
    {
      "type": "cargo-workspace",
      "merge": false
    },
    {
      "type": "node-workspace",
      "merge": false,
      "updatePeerDependencies": true
    },
    {
      "type": "linked-versions",
      "groupName": "arete",
      "components": [
        "arete",
        "arete-interpreter",
        "arete-sdk",
        "arete-macros",
        "a4-cli",
        "arete-server",
        "arete-react",
        "arete-typescript",
        "arete-stacks",
        "a4-npm"
      ]
    }
  ]
}
