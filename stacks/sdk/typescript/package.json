{
  "name": "@usearete/stacks",
  "version": "0.0.1",
  "description": "Protocol stacks for Arete - ready-to-use Solana data streams",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ore": {
      "types": "./dist/ore/index.d.ts",
      "import": "./dist/ore/index.js",
      "require": "./dist/ore/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@usearete/react": ">=0.0.1",
    "@usearete/sdk": ">=0.0.1"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "peerDependenciesMeta": {
    "@usearete/react": {
      "optional": true
    },
    "@usearete/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@usearete/sdk": "file:../../../typescript/core",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "arete",
    "solana",
    "blockchain",
    "streaming"
  ],
  "author": "Arete Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AreteA4/arete.git",
    "directory": "stacks/sdk/typescript"
  },
  "publishConfig": {
    "access": "public"
  }
}
